SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
NEWSAPI_KEY=your-newsapi-key

# Reserved for later analysis and integrations.
# For GitHub Models, use a PAT with the "models: read" permission.
OPENAI_API_KEY=github_pat_your-token
OPENAI_BASE_URL=https://models.github.ai/inference
OPENAI_MODEL=openai/gpt-4.1-mini
DOMAIN_PROFILE=football-v1
GOOGLE_FACT_CHECK_API_KEY=
# Comma-separated RSS or Atom feed URLs.
RSS_FEED_URLS=
PRIMARY_SOURCE_DOMAINS=
# Exact frontend origins allowed to read the API; never use * in production.
API_CORS_ORIGINS=http://localhost:3000
API_TOPIC_RATE_LIMIT=10
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
